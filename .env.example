# Leave DATABASE_URL unset to use local seed fallback from src/lib/events-repo.ts
# DATABASE_URL=

# Supabase Postgres transaction pooler (recommended for Vercel / serverless):
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
PG_SSL=true

# Optional pool tuning for pg (defaults are safe for MVP):
# PG_POOL_MAX=2
# PG_CONNECT_TIMEOUT_MS=5000
# PG_IDLE_TIMEOUT_MS=10000
